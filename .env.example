# FocusPulse Email Configuration Template
# ---------------------------------------------
# Copy this file to '.env' and fill in your real credentials.
# For Gmail, you MUST use an "App Password" if 2FA is enabled.

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password
MAIL_DEFAULT_SENDER=noreply@focuspulse.app
